{
  "name": "automyrix-framework",
  "version": "1.0.0",
  "description": "Unified AI-Driven Automation Framework",
  "private": true,
  "scripts": {
    "install:all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "startup": "node scripts/startup.js",
    "dev": "node scripts/startup.js",
    "dev:original": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "mongodb": "^7.2.0"
  }
}
